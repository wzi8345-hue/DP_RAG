# ── DP-RAG 部署环境变量（复制为 deploy/.env） ─────────────────────────

# 镜像（CI 推送的具体 tag，不使用 latest）。
# tag 格式：sci-loop_{backend|frontend}_<yymmdd>_<commit_sha 前4位>，见 Actions 构建日志 / 镜像仓库。
BACKEND_IMAGE=dp-harbor-registry.cn-zhangjiakou.cr.aliyuncs.com/dplc/qsar:sci-loop_backend_<yymmdd>_<sha4>
FRONTEND_IMAGE=dp-harbor-registry.cn-zhangjiakou.cr.aliyuncs.com/dplc/qsar:sci-loop_frontend_<yymmdd>_<sha4>

# ── 后端：监听 ───────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8080
# 反代将 https://funmg.dp.tech/sci-loop-api 转发到后端；若反代不剥离前缀，设 root_path
API_ROOT_PATH=

# 允许的前端来源（CORS，必填）
# 逗号分隔、无空格；须与浏览器实际 Origin 完全一致（含协议与端口）。
# 生产前端 GitHub Pages：https://rag.hal9k.one
# 本地 Vite dev server：http://localhost:9527
# 使用 Logto JWT 时勿设为 *（带 Authorization 的跨域请求需显式来源 + credentials）。
CORS_ORIGINS=https://rag.hal9k.one,http://localhost:9527

# ── Logto 鉴权（后端本地校验 JWT） ──────────────────────
LOGTO_ISSUER=https://auth.dplink.cc/oidc
LOGTO_JWKS_URI=https://auth.dplink.cc/oidc/jwks
LOGTO_AUDIENCE=https://funmg.dp.tech/sci-loop-api
LOGTO_REQUIRED_SCOPE=all:data
LOGTO_ROLE_USER=sci-loop-user
LOGTO_ROLE_ADMIN=sci-loop-admin
LOGTO_ROLE_ROOT=sci-loop-root
# 本地开发可设 1 跳过鉴权（用固定 dev 用户）；生产务必为 0
AUTH_DISABLED=0

# ── 数据库（对话消息树 / 归属 / 可见性） ───────────────
# 直接用 psycopg 3，DATABASE_URL 为标准 libpq URL（不要 +psycopg 后缀）
POSTGRES_USER=dprag
POSTGRES_PASSWORD=change-me
POSTGRES_DB=dprag
DATABASE_URL=postgresql://dprag:change-me@postgres:5432/dprag
# 连接池大小（可选）
DB_POOL_MIN=1
DB_POOL_MAX=10

# ── 存储 / 会话 ─────────────────────────────────────────
UPLOAD_DIR=/data/uploads
SESSION_DIR=/data/sessions
TASK_DIR=/data/tasks
TASK_MAX_WORKERS=2
UPLOAD_MAX_FILES=200
UPLOAD_MAX_TOTAL_MB=500

# ── Redis（生产级对话 run queue + SSE stream fanout） ──────
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379
REDIS_RUN_QUEUE=dprag:generation:runs
REDIS_RUN_STREAM_PREFIX=dprag:generation:stream
REDIS_RUN_STREAM_MAXLEN=2000
REDIS_RUN_STREAM_TTL=86400
REDIS_INGEST_QUEUE=dprag:ingest:tasks
REDIS_INGEST_STREAM_PREFIX=dprag:ingest:stream
REDIS_INGEST_STREAM_MAXLEN=2000
REDIS_INGEST_STREAM_TTL=86400
INGEST_WORKER_CONCURRENCY=1
INGEST_CANCEL_CHECK_INTERVAL=1

# ── 对象存储（RustFS / S3 compatible，用于 PDF 原文与解析产物） ──
OBJECT_STORE_ENDPOINT=http://rustfs:9000
# 浏览器可访问的外部地址；生产请设为反代后的 HTTPS 域名
OBJECT_STORE_PUBLIC_ENDPOINT=http://localhost:9000
OBJECT_STORE_PORT=9000
OBJECT_STORE_ACCESS_KEY=dprag
OBJECT_STORE_SECRET_KEY=change-me-object-store
OBJECT_STORE_BUCKET=dprag
OBJECT_STORE_REGION=us-east-1

# ── 基建服务连接（环境变量覆盖 pipeline 配置；镜像无需挂载 YAML） ──
# 留空的变量后端会忽略（保留 default_config 默认值）。地址用内网/容器网络可达的 host。
# Embedding
EMBEDDING_API_BASE=http://embedding:8002/v1
EMBEDDING_API_KEY=EMPTY
EMBEDDING_MODEL=/models/Qwen3-Embedding-4B
# Milvus（必须与 embedding 模型维度一致：4B=2560）
MILVUS_BACKEND=server
MILVUS_URI=http://milvus:19530
MILVUS_PORT=19530
MILVUS_METRICS_PORT=9091
MILVUS_TOKEN=
MILVUS_DB_NAME=
# 单物理 Milvus collection；业务知识库用 Postgres kb_id + Milvus row.kb_id 区分
MILVUS_COLLECTION=literature_chunks
MILVUS_DIM=2560
# 生成 LLM
LLM_API_BASE=http://llm:8000/v1
LLM_API_KEY=EMPTY
LLM_MODEL=/models/Qwen3.5-9B
# Reranker
RERANKER_API_BASE=http://reranker:8001/v1
RERANKER_API_KEY=EMPTY
RERANKER_MODEL=/models/Qwen3-Reranker-4B
# Reflection LLM（留空则复用生成 LLM）
REFLECTION_API_BASE=http://llm:8000/v1
REFLECTION_API_KEY=EMPTY
REFLECTION_MODEL=/models/Qwen3.5-9B
# 解析后端（PDF）
PARSER_BACKEND=mineru
MINERU_AUTHORIZATION=
UNIPARSER_API_KEY=

# ── 可选：用 YAML 提供额外/算法参数（环境变量优先级更高） ──
# 设置后需在 compose 挂载对应文件，留空则仅用 default_config + 上面的环境变量
CONFIG_PATH=
